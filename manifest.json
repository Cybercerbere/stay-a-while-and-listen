{
  "manifest_version": 3,
  "name": "POC Speechify",
  "version": "1.0.0",
  "description": "Building a text to speech extension to understand Speechify's product",
  "permissions": [],
  "action": {
    "default_icon": {
      "16": "icons/16x16.png",
      "32": "icons/32x32.png",
      "48": "icons/48x48.png",
      "128": "icons/128x128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/main.js"],
      "all_frames": false,
      "run_at": "document_end",
      "world": "ISOLATED"
    }
  ]
}
